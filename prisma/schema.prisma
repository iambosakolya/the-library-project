generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String      @unique(map: "slug_index")
  category    String
  description String
  images      String[]
  price       Decimal     @default(0) @db.Decimal(12, 2)
  author      String
  rating      Decimal     @default(0) @db.Decimal(3, 2)
  stock       Int
  numReviews  Int         @default(0)
  isFeatured  Boolean     @default(false)
  banner      String?
  createdAt   DateTime    @default(now()) @db.Timestamp(6)
  OrderItem   OrderItem[]
  reviews     Review[]
}

model Review {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String         @db.Uuid
  productId String         @db.Uuid
  rating    Int
  comment   String
  createdAt DateTime       @default(now()) @db.Timestamp(6)
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  replies   ReviewReply[]
  reports   ReviewReport[] @relation("ReviewReports")
  votes     ReviewVote[]

  @@unique([userId, productId])
  @@index([productId])
}

model ReviewReply {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String         @db.Uuid
  reviewId  String         @db.Uuid
  parentId  String?        @db.Uuid
  depth     Int            @default(1)
  comment   String
  createdAt DateTime       @default(now()) @db.Timestamp(6)
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review         @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  parent    ReviewReply?   @relation("ReplyToReply", fields: [parentId], references: [id], onDelete: Cascade)
  children  ReviewReply[]  @relation("ReplyToReply")
  reports   ReviewReport[] @relation("ReplyReports")

  @@index([reviewId])
  @@index([parentId])
}

model ReviewReport {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String       @db.Uuid
  reviewId    String?      @db.Uuid
  replyId     String?      @db.Uuid
  reason      String
  description String?
  createdAt   DateTime     @default(now()) @db.Timestamp(6)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  review      Review?      @relation("ReviewReports", fields: [reviewId], references: [id], onDelete: Cascade)
  reply       ReviewReply? @relation("ReplyReports", fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@unique([userId, replyId])
}

model ReviewVote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  reviewId  String   @db.Uuid
  isHelpful Boolean
  createdAt DateTime @default(now()) @db.Timestamp(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@index([reviewId])
}

model UserFollow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model User {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String           @default("No_Name")
  email           String           @unique(map: "user_email_idx")
  emailVerified   DateTime?        @db.Timestamp(6)
  image           String?
  password        String?
  role            String           @default("user")
  address         Json?            @db.Json
  paymentMethod   String?
  createdAt       DateTime         @default(now()) @db.Timestamp(6)
  updatedAt       DateTime         @updatedAt
  Account         Account[]
  attendances     Attendance[]
  bookSubmissions BookSubmission[]
  Cart            Cart[]
  ClubRequest     ClubRequest[]
  organizedEvents Event[]          @relation("EventOrganizer")
  Order           Order[]
  createdClubs    ReadingClub[]    @relation("ClubCreator")
  registrations   Registration[]
  Session         Session[]
  reviews         Review[]
  reviewReplies   ReviewReply[]
  reviewReports   ReviewReport[]
  reviewVotes     ReviewVote[]
  followers       UserFollow[]     @relation("UserFollowing")
  following       UserFollow[]     @relation("UserFollowers")
}

model Account {
  userId            String   @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now()) @db.Timestamp(6)
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamp(6)
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Cart {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?  @db.Uuid
  sessionCartId String
  items         Json[]   @default([]) @db.Json
  itemsPrice    Decimal  @db.Decimal(12, 2)
  totalPrice    Decimal  @db.Decimal(12, 2)
  shippingPrice Decimal  @db.Decimal(12, 2)
  taxPrice      Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String      @db.Uuid
  shippingAddress Json        @db.Json
  paymentMethod   String
  paymentResult   Json?       @db.Json
  itemsPrice      Decimal     @db.Decimal(12, 2)
  shippingPrice   Decimal     @db.Decimal(12, 2)
  taxPrice        Decimal     @db.Decimal(12, 2)
  totalPrice      Decimal     @db.Decimal(12, 2)
  isPaid          Boolean     @default(false)
  paidAt          DateTime?   @db.Timestamp(6)
  isDelivered     Boolean     @default(false)
  deliveredAt     DateTime?   @db.Timestamp(6)
  createdAt       DateTime    @default(now()) @db.Timestamp(6)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderitems      OrderItem[]
}

model OrderItem {
  orderId   String  @db.Uuid
  productId String  @db.Uuid
  quantity  Int
  price     Decimal @db.Decimal(12, 2)
  name      String
  slug      String
  image     String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([orderId, productId], map: "orderitems_orderId_productId_pk")
}

model ClubRequest {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String          @db.Uuid
  type            ClubEventType
  title           String
  purpose         String
  description     String
  startDate       DateTime        @db.Timestamp(6)
  endDate         DateTime?       @db.Timestamp(6)
  capacity        Int
  format          ClubEventFormat
  address         String?
  onlineLink      String?
  sessionCount    Int
  bookIds         String[]
  status          ClubEventStatus @default(pending)
  rejectionReason String?
  createdAt       DateTime        @default(now()) @db.Timestamp(6)
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  event           Event?
  readingClub     ReadingClub?
}

model ReadingClub {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubRequestId String          @unique @db.Uuid
  title         String
  purpose       String
  description   String
  startDate     DateTime        @db.Timestamp(6)
  endDate       DateTime?       @db.Timestamp(6)
  capacity      Int
  format        ClubEventFormat
  address       String?
  onlineLink    String?
  sessionCount  Int
  bookIds       String[]
  creatorId     String          @db.Uuid
  memberIds     String[]        @default([])
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now()) @db.Timestamp(6)
  updatedAt     DateTime        @updatedAt
  changeHistory Json[]          @default([]) @db.Json
  attendances   Attendance[]    @relation("ClubAttendances")
  clubRequest   ClubRequest     @relation(fields: [clubRequestId], references: [id], onDelete: Cascade)
  creator       User            @relation("ClubCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  registrations Registration[]  @relation("ClubRegistrations")
}

model Event {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventRequestId String          @unique @db.Uuid
  title          String
  purpose        String
  description    String
  eventDate      DateTime        @db.Timestamp(6)
  capacity       Int
  format         ClubEventFormat
  address        String?
  onlineLink     String?
  bookIds        String[]
  organizerId    String          @db.Uuid
  attendeeIds    String[]        @default([])
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now()) @db.Timestamp(6)
  updatedAt      DateTime        @updatedAt
  changeHistory  Json[]          @default([]) @db.Json
  attendances    Attendance[]    @relation("EventAttendances")
  eventRequest   ClubRequest     @relation(fields: [eventRequestId], references: [id], onDelete: Cascade)
  organizer      User            @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  registrations  Registration[]  @relation("EventRegistrations")
}

model Registration {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String             @db.Uuid
  clubId       String?            @db.Uuid
  eventId      String?            @db.Uuid
  status       RegistrationStatus @default(active)
  registeredAt DateTime           @default(now()) @db.Timestamp(6)
  cancelledAt  DateTime?          @db.Timestamp(6)
  createdAt    DateTime           @default(now()) @db.Timestamp(6)
  updatedAt    DateTime           @updatedAt
  club         ReadingClub?       @relation("ClubRegistrations", fields: [clubId], references: [id], onDelete: Cascade)
  event        Event?             @relation("EventRegistrations", fields: [eventId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clubId])
  @@index([eventId])
  @@index([userId, clubId, status])
  @@index([userId, eventId, status])
}

model Attendance {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String           @db.Uuid
  clubId        String?          @db.Uuid
  eventId       String?          @db.Uuid
  sessionNumber Int              @default(1)
  status        AttendanceStatus @default(present)
  notes         String?
  markedAt      DateTime         @default(now()) @db.Timestamp(6)
  createdAt     DateTime         @default(now()) @db.Timestamp(6)
  updatedAt     DateTime         @updatedAt
  club          ReadingClub?     @relation("ClubAttendances", fields: [clubId], references: [id], onDelete: Cascade)
  event         Event?           @relation("EventAttendances", fields: [eventId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId, sessionNumber])
  @@unique([userId, eventId, sessionNumber])
  @@index([clubId])
  @@index([eventId])
}

model BookSubmission {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String               @db.Uuid
  title           String
  author          String
  isbn            String?
  isbn13          String?
  publisher       String?
  publishedDate   String?
  description     String
  pageCount       Int?
  language        String?
  categories      String[]             @default([])
  coverImage      String?
  thumbnailImage  String?
  previewLink     String?
  googleBooksId   String?
  status          BookSubmissionStatus @default(pending)
  rejectionReason String?
  adminNotes      String?
  productId       String?              @db.Uuid
  createdAt       DateTime             @default(now()) @db.Timestamp(6)
  updatedAt       DateTime             @updatedAt
  isForSale       Boolean              @default(false)
  suggestedPrice  Decimal?             @db.Decimal(12, 2)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([isbn])
  @@index([isbn13])
}

enum ClubEventType {
  club
  event
}

enum ClubEventStatus {
  pending
  approved
  rejected
}

enum ClubEventFormat {
  online
  offline
}

enum RegistrationStatus {
  active
  cancelled
}

enum AttendanceStatus {
  present
  absent
  excused
}

enum BookSubmissionStatus {
  pending
  approved
  rejected
}
